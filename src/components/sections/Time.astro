---
import TeamMember from "../ui/TeamMember.astro";

import marcio from "../../images/marcio.jpeg";
import gisele from "../../images/gisele.jpeg";
import igor from "../../images/igor.jpeg";
import gabriel from "../../images/gabriel.jpeg";
---

<section id="time" class="section team">
  <div class="container">
    <h2 class="section-title">Conheça o Time</h2>

    <div class="team-grid">
      <TeamMember
        image={marcio}
        name="Marcio Magrini"
        role="Founder"
      />

      <TeamMember
        image={gisele}
        name="Gisele Corbanezi"
        role="Head de Operações"
      />

      <TeamMember
        image={igor}
        name="Igor Mandello"
        role="Head de Tecnologia"
      />

      <TeamMember
        image={gabriel}
        name="Gabriel Siqueira"
        role="Head de Descarbonização"
      />
    </div>
  </div>
</section>

<style lang="scss">
.team {
  background-color: var(--color-bg-secondary);
  
  &-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
    padding: 0 var(--spacing-md);
  }

  @media (min-width: 900px) {
    &-grid {
      gap: var(--spacing-xl);
      grid-template-columns: repeat(4, 1fr);
    }
  }
}
</style>
